# Supabase — get these from your Supabase project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role — NEVER expose this to the browser
# Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# App config
NEXT_PUBLIC_APP_NAME=WITHOUT EQUAL
NEXT_PUBLIC_CUTOFF_HOUR=8
NEXT_PUBLIC_CUTOFF_MINUTE=30

# ── PWA Push Notifications ───────────────────────────────────
# Generate VAPID keys by running:
#   npx web-push generate-vapid-keys
# Then copy the output below.

# Public key — safe to expose to the browser
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BEIMPVHhpXYlynt1c83JAx0IXF2RRgOAnxn2d2YE2Hm9PD55OBYFfAOnM9dN2PgYPmdf_gJKJ2-1ko9TGl88R68

# Private key — keep secret, server-side only
VAPID_PRIVATE_KEY=z--4k8NN1RDMPnf_dRn7CoLtYJ5sSgVRFeNbmlHwQl0

# Contact email for VAPID (required by push services)
VAPID_EMAIL=wilsonlow.sg@gmail.com

# Random secret to protect the /api/push/notify cron endpoint
# Generate with: openssl rand -base64 32
CRON_SECRET=your-cron-secret-here
